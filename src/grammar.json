{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "bat",
  "word": "identifier",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_statement"
      }
    },
    "shebang": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#!"
        },
        {
          "type": "PATTERN",
          "value": ".*"
        }
      ]
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "REM"
              },
              {
                "type": "STRING",
                "value": "rem"
              },
              {
                "type": "STRING",
                "value": "Rem"
              },
              {
                "type": "STRING",
                "value": "@REM"
              },
              {
                "type": "STRING",
                "value": "@rem"
              }
            ]
          },
          {
            "type": "PATTERN",
            "value": ".*"
          }
        ]
      }
    },
    "_statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "label"
        },
        {
          "type": "SYMBOL",
          "name": "command"
        }
      ]
    },
    "label": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": ":"
          },
          {
            "type": "FIELD",
            "name": "name",
            "content": {
              "type": "SYMBOL",
              "name": "identifier"
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "\\r?\\n"
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "command": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "@"
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "FIELD",
            "name": "name",
            "content": {
              "type": "SYMBOL",
              "name": "command_name"
            }
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "FIELD",
              "name": "argument",
              "content": {
                "type": "SYMBOL",
                "name": "_argument"
              }
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "\\r?\\n"
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "command_name": {
      "type": "SYMBOL",
      "name": "identifier"
    },
    "_argument": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "variable"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "redirect_operator"
        },
        {
          "type": "SYMBOL",
          "name": "pipe_operator"
        },
        {
          "type": "SYMBOL",
          "name": "flag"
        },
        {
          "type": "SYMBOL",
          "name": "path"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "parenthesized"
        }
      ]
    },
    "string": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\""
        },
        {
          "type": "PATTERN",
          "value": "[^\"]*"
        },
        {
          "type": "STRING",
          "value": "\""
        }
      ]
    },
    "number": {
      "type": "PATTERN",
      "value": "\\d+"
    },
    "path": {
      "type": "PATTERN",
      "value": "[%~]?[A-Za-z]:\\\\[^\\s\"<>|]+"
    },
    "flag": {
      "type": "PREC_LEFT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "/"
          },
          {
            "type": "PATTERN",
            "value": "[A-Za-z0-9]+"
          }
        ]
      }
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_\\-]*"
    },
    "parenthesized": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_argument"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "variable": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "special_variable"
        },
        {
          "type": "SYMBOL",
          "name": "parameter_variable"
        },
        {
          "type": "SYMBOL",
